{
  tweaks: {
    /*
     * If true, tweaks loot tables so that loot generated in chests as well as modded materials dropped from broken blocks are replaced by their FTB Materials counterparts. Vanilla loot is not affected.
     * Default: true
     */
    tweak_loot_tables: true,
    /*
     * If true, tweaks recipes during the recipe manager load phase so that all relevant modded inputs & outputs use their FTB Materials counterparts instead. Vanilla materials are not affected.
     * Default: true
     */
    tweak_recipes: true,
    /*
     * If true, tweaks worldgen so that any modded generated ores are replaced by their FTB Materials counterparts. Vanilla ores are not affected.
     * Default: true
     */
    tweak_worldgen: true,
  },
}